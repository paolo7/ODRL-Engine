@prefix ns1: <https://w3id.org/force/sotw#> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.com/iri/request_uid#3> odrl:permission <http://example.com/iri/permission_uid#3> .

<http://example.com/iri/context_uid#3_0> a odrl:Constraint ;
    odrl:leftOperand odrl:resolution ;
    odrl:operator odrl:eq ;
    odrl:rightOperand 1.142e+03 .

<http://example.com/iri/permission_uid#3> a odrl:Permission ;
    odrl:action odrl:print ;
    odrl:assignee <http://example.com/org:John> ;
    odrl:target <http://example.com/document:1234> ;
    ns1:context <http://example.com/iri/context_uid#3_0> .

