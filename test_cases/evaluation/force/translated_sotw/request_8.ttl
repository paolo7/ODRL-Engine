@prefix ns1: <https://w3id.org/force/sotw#> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.com/iri/request_uid#8> odrl:permission <http://example.com/iri/permission_uid#8> .

<http://example.com/iri/context_uid#8_0> a odrl:Constraint ;
    odrl:leftOperand <http://www.example.com/age> ;
    odrl:operator odrl:eq ;
    odrl:rightOperand -2.2e+01 .

<http://example.com/iri/context_uid#8_1> a odrl:Constraint ;
    odrl:leftOperand odrl:resolution ;
    odrl:operator odrl:eq ;
    odrl:rightOperand 6.3e+01 .

<http://example.com/iri/context_uid#8_2> a odrl:Constraint ;
    odrl:leftOperand odrl:adminLevel ;
    odrl:operator odrl:eq ;
    odrl:rightOperand 2.6e+01 .

<http://example.com/iri/permission_uid#8> a odrl:Permission ;
    odrl:action odrl:create ;
    odrl:assignee <http://example.com/org:AccountManager> ;
    odrl:target <http://example.com/document:1234> ;
    ns1:context <http://example.com/iri/context_uid#8_0>,
        <http://example.com/iri/context_uid#8_1>,
        <http://example.com/iri/context_uid#8_2> .

